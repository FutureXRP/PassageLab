# PassageLab — environment variables
# Copy to .env.local for local dev; set the same values in Vercel → Project → Settings → Environment Variables.

# ── Anthropic (required — study generation) ─────────────────────────────────
ANTHROPIC_API_KEY=

# ── Supabase (required — auth, caching, usage tracking, waitlist) ───────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe (required — payments) ────────────────────────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret (Stripe Dashboard → Developers → Webhooks →
# endpoint https://<domain>/api/webhooks/stripe)
STRIPE_WEBHOOK_SECRET=

# ── Cron protection (REQUIRED — billing refuses to run without it) ──────────
# Vercel sends it as "Authorization: Bearer <CRON_SECRET>" to
# /api/billing/charge; the route rejects any other caller.
CRON_SECRET=

# ── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://passagelab.app

# ── Book verification (optional — /api/verify-books) ────────────────────────
# Google Books is used to confirm a recommended book's canonical ISBN-13
# before the Books tab links to it. A key is OPTIONAL (it works without one,
# at lower rate limits) — get one at https://console.cloud.google.com/ →
# enable the Books API → create an API key.
GOOGLE_BOOKS_API_KEY=

# ── Affiliates (Books tab links for verified books) ─────────────────────────
# Amazon Associates tag, appended at serve time to links for books that the
# verification job has confirmed (lib/book-catalog → attachVerifiedLinks).
# Links only ever point at verified ISBNs, so they don't 404.
NEXT_PUBLIC_AMAZON_AFFILIATE_TAG=passagelab-20
