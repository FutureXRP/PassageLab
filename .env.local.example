# PassageLab — environment variables
# Copy to .env.local for local dev; set the same values in Vercel → Project → Settings → Environment Variables.

# ── Anthropic (required — study generation) ─────────────────────────────────
ANTHROPIC_API_KEY=

# ── Supabase (required — auth, caching, usage tracking, waitlist) ───────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe (required — payments) ────────────────────────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret (Stripe Dashboard → Developers → Webhooks →
# endpoint https://<domain>/api/webhooks/stripe)
STRIPE_WEBHOOK_SECRET=

# ── Cron protection (REQUIRED — billing refuses to run without it) ──────────
# Vercel sends it as "Authorization: Bearer <CRON_SECRET>" to
# /api/billing/charge; the route rejects any other caller.
CRON_SECRET=

# ── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://passagelab.app

# ── Academic tier (feature flag) ─────────────────────────────────────────────
# The $20 Academic tier (Opus-powered, doctoral-grade research apparatus) is
# OFF by default. While off it is completely invisible and inert — the app
# behaves exactly as it did with only Quick/Deep. Set to "true" and redeploy to
# turn it on. BEFORE enabling, run schema.sql so usage_events.study_type accepts
# 'academic' (the migration is included and idempotent).
NEXT_PUBLIC_ACADEMIC_ENABLED=false

# ── Admin dashboard (/admin) ─────────────────────────────────────────────────
# Comma-separated emails allowed to access /admin and the /api/admin/* routes
# (reporting, coupons, refunds, render failures). Enforced server-side only —
# never exposed to the browser. Leave empty to lock everyone out of admin.
ADMIN_EMAILS=

# ── Limits (optional) ───────────────────────────────────────────────────────
# Max verses a single study may cover. /api/tab rejects longer passages before
# any model call so the per-verse tabs can't truncate/time out. Default 40.
MAX_PASSAGE_VERSES=40

# Optional platform-wide monthly spend cap (USD) per user, applied when a user
# hasn't set their own limit. Under the pay-at-unlock model the customer is
# charged immediately, so there is no pre-collection exposure to bound — a
# platform default would just block a willing payer. Default is now 0 (off);
# only a user's own self-set limit blocks. Set a positive number here to
# re-enable a platform-wide default.
DEFAULT_MONTHLY_CAP=0

# ── Verified-source search (optional — /api/sources) ───────────────────────
# OpenAlex + Crossref ask for a contact email for their free "polite pool"
# (faster, more reliable). No key needed. Defaults to support@passagelab.app.
SOURCES_CONTACT_EMAIL=

# ── Book verification (optional — /api/verify-books) ────────────────────────
# Google Books is used to confirm a recommended book's canonical ISBN-13
# before the Books tab links to it. A key is OPTIONAL (it works without one,
# at lower rate limits) — get one at https://console.cloud.google.com/ →
# enable the Books API → create an API key.
GOOGLE_BOOKS_API_KEY=

# ── Affiliates (Books tab links for verified books) ─────────────────────────
# Amazon Associates tag, appended at serve time to links for books that the
# verification job has confirmed (lib/book-catalog → attachVerifiedLinks).
# Links only ever point at verified ISBNs, so they don't 404.
NEXT_PUBLIC_AMAZON_AFFILIATE_TAG=passagelab-20
