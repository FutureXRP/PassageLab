# PassageLab — environment variables
# Copy to .env.local for local dev; set the same values in Vercel → Project → Settings → Environment Variables.

# ── Anthropic (required — study generation) ─────────────────────────────────
ANTHROPIC_API_KEY=

# ── Supabase (required — auth, caching, usage tracking, waitlist) ───────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe (required — payments) ────────────────────────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Metered price IDs (Stripe Dashboard → Products → usage-based prices)
STRIPE_QUICK_STUDY_PRICE_ID=
STRIPE_DEEP_DIVE_PRICE_ID=

# ── Cron protection (recommended) ───────────────────────────────────────────
# When set, Vercel sends it as "Authorization: Bearer <CRON_SECRET>" to
# /api/billing/charge; the route rejects any other caller.
CRON_SECRET=

# ── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://passagelab.app

# ── Affiliates (optional — Books tab links) ─────────────────────────────────
NEXT_PUBLIC_AMAZON_AFFILIATE_TAG=passagelab-20
NEXT_PUBLIC_LOGOS_AFFILIATE_REF=passagelab
NEXT_PUBLIC_CBD_AFFILIATE_ID=passagelab
